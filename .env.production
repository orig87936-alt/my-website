# 🚀 前端生产环境配置
# 用于 Vite 构建时的环境变量

# ============================================================
# API 配置 (必须修改为你的实际 API 地址)
# ============================================================
# 使用 EC2 公网 IP (注意：变量名是 VITE_API_BASE_URL，不包含 /api)
# 使用 HTTP 避免自签名证书问题
VITE_API_BASE_URL=http://18.221.125.254:8000

# ============================================================
# 应用配置
# ============================================================
VITE_APP_NAME=S&L News Platform
VITE_APP_VERSION=1.0.0
VITE_ENVIRONMENT=production

# ============================================================
# 功能开�?# ============================================================
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_ERROR_TRACKING=true
VITE_ENABLE_DEBUG=false

# ============================================================
# Google OAuth (可�?
# ============================================================
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# ============================================================
# 使用说明
# ============================================================
# 1. �?VITE_API_URL 改为你的实际后端 API 地址
# 2. 运行 npm run build 构建生产版本
# 3. 构建产物�?build/ 目录
# 4. 上传�?S3 或其他静态托管服�?
