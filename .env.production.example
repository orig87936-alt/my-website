# ========================================
# 前端生产环境配置模板
# 复制此文件为 .env.production 并填入实际值
# ========================================

# ========================================
# 后端 API 地址
# 更新为你的实际后端域名
# ========================================
VITE_API_BASE_URL=https://api.yourdomain.com

# ========================================
# Google OAuth
# 从 Google Cloud Console 获取
# ========================================
VITE_GOOGLE_CLIENT_ID=123456789-xxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com

